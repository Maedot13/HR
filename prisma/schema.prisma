generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model ActivityLog {
  id            String   @id @default(uuid())
  actingUserId  String
  actingRole    String
  actionType    String
  resourceType  String
  resourceId    String
  previousState Json?
  newState      Json?
  ipAddress     String
  timestamp     DateTime @default(now())
  Employee      Employee @relation(fields: [actingUserId], references: [id])
}

model Application {
  id                   String             @id @default(uuid())
  jobPostingId         String
  candidateName        String
  candidateEmail       String
  submittedAt          DateTime           @default(now())
  currentStage         RecruitmentStage   @default(SCREENING)
  publicationEvalScore Float?
  JobPosting           JobPosting         @relation(fields: [jobPostingId], references: [id])
  ApplicationStage     ApplicationStage[]
}

model ApplicationStage {
  id             String           @id @default(uuid())
  applicationId  String
  stage          RecruitmentStage
  transitionedAt DateTime         @default(now())
  transitionedBy String
  Application    Application      @relation(fields: [applicationId], references: [id])
}

model AssetAssignment {
  id                   String             @id @default(uuid())
  onboardingWorkflowId String
  assetName            String
  assignedAt           DateTime?
  isAssigned           Boolean            @default(false)
  OnboardingWorkflow   OnboardingWorkflow @relation(fields: [onboardingWorkflowId], references: [id])
}

model Campus {
  id                String              @id @default(uuid())
  code              String              @unique
  name              String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  College           College[]
  Employee          Employee[]
  EmployeeIDCounter EmployeeIDCounter[]
}

model ClearanceBody {
  id            String          @id @default(uuid())
  name          String          @unique
  approvalMode  ApprovalMode    @default(PARALLEL)
  order         Int
  ClearanceTask ClearanceTask[]
}

model ClearanceRecord {
  id            String          @id @default(uuid())
  employeeId    String          @unique
  status        ClearanceStatus @default(IN_PROGRESS)
  initiatedAt   DateTime        @default(now())
  completedAt   DateTime?
  Employee      Employee        @relation(fields: [employeeId], references: [id])
  ClearanceTask ClearanceTask[]
}

model ClearanceTask {
  id                String              @id @default(uuid())
  clearanceRecordId String
  clearanceBodyId   String
  status            ClearanceTaskStatus @default(PENDING)
  approvedBy        String?
  approvedAt        DateTime?
  rejectionReason   String?
  updatedAt         DateTime            @updatedAt
  ClearanceBody     ClearanceBody       @relation(fields: [clearanceBodyId], references: [id])
  ClearanceRecord   ClearanceRecord     @relation(fields: [clearanceRecordId], references: [id])
}

model College {
  id         String       @id @default(uuid())
  name       String
  campusId   String
  Campus     Campus       @relation(fields: [campusId], references: [id])
  Department Department[]
}

model Department {
  id        String     @id @default(uuid())
  name      String
  collegeId String
  College   College    @relation(fields: [collegeId], references: [id])
  Employee  Employee[]
  Unit      Unit[]
}

model Employee {
  id                 String               @id @default(uuid())
  employeeId         String               @unique
  fullName           String
  dateOfBirth        DateTime
  gender             Gender
  nationality        String
  contactInfo        Json
  emergencyContact   Json
  academicRank       AcademicRank?
  status             EmployeeStatus       @default(PENDING)
  campusId           String
  departmentId       String?
  unitId             String?
  hireDate           DateTime?
  endDate            DateTime?
  passwordHash       String
  isTempPassword     Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  ActivityLog        ActivityLog[]
  ClearanceRecord    ClearanceRecord?
  Campus             Campus               @relation(fields: [campusId], references: [id])
  Department         Department?          @relation(fields: [departmentId], references: [id])
  Unit               Unit?                @relation(fields: [unitId], references: [id])
  EmployeeDocument   EmployeeDocument[]
  EmploymentHistory  EmploymentHistory[]
  Evaluation         Evaluation[]
  ExperienceLetter   ExperienceLetter[]
  LeaveApplication   LeaveApplication[]
  LeaveBalance       LeaveBalance[]
  ScheduleEntry      ScheduleEntry[]
  TrainingAssignment TrainingAssignment[]
  UserRole           UserRole?
  email String @unique
}

model EmployeeDocument {
  id           String   @id @default(uuid())
  employeeId   String
  documentType String
  fileUrl      String
  uploadedAt   DateTime @default(now())
  uploadedBy   String
  Employee     Employee @relation(fields: [employeeId], references: [id])
}

model EmployeeIDCounter {
  id       String @id @default(uuid())
  campusId String
  year     Int
  sequence Int    @default(0)
  Campus   Campus @relation(fields: [campusId], references: [id])

  @@unique([campusId, year])
}

model EmploymentHistory {
  id            String   @id @default(uuid())
  employeeId    String
  changeType    String
  previousValue String?
  newValue      String
  changedBy     String
  changedAt     DateTime @default(now())
  Employee      Employee @relation(fields: [employeeId], references: [id])
}

model Evaluation {
  id               String   @id @default(uuid())
  employeeId       String
  evaluationPeriod String
  efficiencyScore  Float
  workOutputScore  Float
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  Employee         Employee @relation(fields: [employeeId], references: [id])
}

model ExperienceLetter {
  id          String       @id @default(uuid())
  employeeId  String
  generatedBy String
  generatedAt DateTime     @default(now())
  format      LetterFormat
  fileUrl     String
  Employee    Employee     @relation(fields: [employeeId], references: [id])
}

model JobPosting {
  id           String        @id @default(uuid())
  type         PostingType
  title        String
  description  String
  requirements String
  deadline     DateTime
  isAcademic   Boolean       @default(false)
  createdBy    String
  createdAt    DateTime      @default(now())
  Application  Application[]
}

model LeaveApplication {
  id              String      @id @default(uuid())
  employeeId      String
  leaveTypeId     String
  startDate       DateTime
  endDate         DateTime
  reason          String
  status          LeaveStatus @default(PENDING)
  rejectionReason String?
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime    @default(now())
  supportingDocs  String[]
  Employee        Employee    @relation(fields: [employeeId], references: [id])
  LeaveType       LeaveType   @relation(fields: [leaveTypeId], references: [id])
}

model LeaveBalance {
  id          String    @id @default(uuid())
  employeeId  String
  leaveTypeId String
  balance     Float     @default(0)
  year        Int
  Employee    Employee  @relation(fields: [employeeId], references: [id])
  LeaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveType {
  id               String             @id @default(uuid())
  name             LeaveTypeName      @unique
  description      String
  maxDays          Int?
  payRate          Float              @default(1.0)
  LeaveApplication LeaveApplication[]
  LeaveBalance     LeaveBalance[]
}

model OnboardingDocument {
  id                   String             @id @default(uuid())
  onboardingWorkflowId String
  documentType         String
  isCollected          Boolean            @default(false)
  collectedAt          DateTime?
  OnboardingWorkflow   OnboardingWorkflow @relation(fields: [onboardingWorkflowId], references: [id])
}

model OnboardingWorkflow {
  id                 String               @id @default(uuid())
  applicationId      String               @unique
  status             OnboardingStatus     @default(PENDING)
  createdAt          DateTime             @default(now())
  AssetAssignment    AssetAssignment[]
  OnboardingDocument OnboardingDocument[]
}

model PayrollExport {
  id              String              @id @default(uuid())
  payrollReportId String
  format          PayrollExportFormat
  fileUrl         String
  exportedAt      DateTime            @default(now())
  PayrollReport   PayrollReport       @relation(fields: [payrollReportId], references: [id])
}

model PayrollReport {
  id            String          @id @default(uuid())
  period        String
  generatedBy   String
  generatedAt   DateTime        @default(now())
  status        ReportStatus    @default(DRAFT)
  PayrollExport PayrollExport[]
}

model Permission {
  id                  String                @id @default(uuid())
  code                String                @unique
  description         String
  PrivilegePermission PrivilegePermission[]
  RolePermission      RolePermission[]
}

model PrivilegePermission {
  id           String           @id @default(uuid())
  privilege    SpecialPrivilege
  permissionId String
  Permission   Permission       @relation(fields: [permissionId], references: [id])

  @@unique([privilege, permissionId])
}

model RolePermission {
  id           String     @id @default(uuid())
  role         BaseRole
  permissionId String
  Permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([role, permissionId])
}

model ScheduleEntry {
  id           String         @id @default(uuid())
  employeeId   String
  course       String
  dayOfWeek    Int
  startTime    String
  endTime      String
  location     String
  createdAt    DateTime       @default(now())
  Employee     Employee       @relation(fields: [employeeId], references: [id])
  Substitution Substitution[]
}

model Substitution {
  id              String        @id @default(uuid())
  scheduleEntryId String
  substituteId    String
  sessionDate     DateTime
  loggedAt        DateTime      @default(now())
  loggedBy        String
  ScheduleEntry   ScheduleEntry @relation(fields: [scheduleEntryId], references: [id])
}

model TrainingAssignment {
  id                 String          @id @default(uuid())
  employeeId         String
  trainingProgramId  String
  assignedDate       DateTime        @default(now())
  expectedCompletion DateTime
  completionDate     DateTime?
  status             TrainingStatus  @default(ASSIGNED)
  Employee           Employee        @relation(fields: [employeeId], references: [id])
  TrainingProgram    TrainingProgram @relation(fields: [trainingProgramId], references: [id])
}

model TrainingProgram {
  id                 String               @id @default(uuid())
  title              String
  description        String
  competencies       String[]
  TrainingAssignment TrainingAssignment[]
}

model Unit {
  id           String     @id @default(uuid())
  name         String
  departmentId String
  Employee     Employee[]
  Department   Department @relation(fields: [departmentId], references: [id])
}

model UserRole {
  id               String            @id @default(uuid())
  employeeId       String            @unique
  baseRole         BaseRole
  specialPrivilege SpecialPrivilege?
  updatedAt        DateTime          @updatedAt
  Employee         Employee          @relation(fields: [employeeId], references: [id])
}

enum AcademicRank {
  LECTURER
  ASSISTANT_PROFESSOR
  ASSOCIATE_PROFESSOR
}

enum ApprovalMode {
  SEQUENTIAL
  PARALLEL
}

enum BaseRole {
  SUPER_ADMIN
  ADMIN
  HR_OFFICER
  EMPLOYEE
}

enum ClearanceStatus {
  IN_PROGRESS
  COMPLETED
}

enum ClearanceTaskStatus {
  PENDING
  ACTIVE
  APPROVED
  REJECTED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveTypeName {
  ANNUAL
  MATERNITY_PRENATAL
  MATERNITY_POSTNATAL
  PATERNITY
  SICK_FULL
  SICK_HALF
  PERSONAL
  SPECIAL
  LEAVE_WITHOUT_PAY
  STUDY
  RESEARCH
  SABBATICAL
  SEMINAR
}

enum LetterFormat {
  PDF
  DOCX
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum PayrollExportFormat {
  EXCEL
  PDF
  DOCX
}

enum PostingType {
  INTERNAL
  EXTERNAL
}

enum RecruitmentStage {
  SCREENING
  INTERVIEW
  SELECTION
  OFFER
}

enum ReportStatus {
  DRAFT
  SENT
  VALIDATED
}

enum SpecialPrivilege {
  UNIVERSITY_PRESIDENT
  VICE_PRESIDENT
  DEAN
  DIRECTOR
}

enum TrainingStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}
